# FacturaGuard backend Railway variables

ENVIRONMENT=production
AUTO_CREATE_TABLES=false

# Generate a long random value before deploy.
SECRET_KEY=replace-with-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Railway reference variable from the PostgreSQL service.
# Adjust service name if your Railway database service is not named Postgres.
DATABASE_URL=${{Postgres.DATABASE_URL}}

# Replace after Railway frontend domain is generated.
CORS_ORIGINS=https://your-frontend.up.railway.app
SECURITY_HEADERS_ENABLED=true
TRUSTED_HOSTS=your-backend.up.railway.app,*.up.railway.app

# Scheduler
FG_ENABLE_SCHEDULER=true
FG_STATUS_CHECK_INTERVAL_MINUTES=60

# Email
FG_EMAIL_DRY_RUN=true
FG_EMAIL_FROM=alerts@facturaguard.local

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120

# Storage option A: Railway Volume mounted at /app/storage
FILE_STORAGE_BACKEND=local
FILE_STORAGE_PATH=/app/storage

# Storage option B: S3-compatible storage
# FILE_STORAGE_BACKEND=s3
# S3_ENDPOINT_URL=
# S3_REGION_NAME=
# S3_BUCKET_NAME=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# Mock NETOPIA
NETOPIA_MOCK_ENABLED=true
NETOPIA_MOCK_RETURN_URL=https://your-frontend.up.railway.app/billing/return
NETOPIA_MOCK_WEBHOOK_SECRET=replace-with-random-webhook-secret

# ANAF/SPV
# Keep mock until your ANAF OAuth app and callback URL are ready.
ANAF_CONNECTOR_MODE=mock
ANAF_ENV=test
ANAF_CLIENT_ID=
ANAF_CLIENT_SECRET=
ANAF_REDIRECT_URI=https://your-backend.up.railway.app/integrations/anaf/oauth/callback
ANAF_AUTH_BASE=https://logincert.anaf.ro/anaf-oauth2/v1
ANAF_API_TEST_BASE=https://webserviceapl.anaf.ro/test/FCTEL/rest
ANAF_API_PROD_BASE=https://webserviceapl.anaf.ro/prod/FCTEL/rest
ANAF_TOKEN_CONTENT_TYPE=jwt
ANAF_SCOPE=
FRONTEND_BASE_URL=https://your-frontend.up.railway.app

# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=


# NETOPIA Payments API v2
# Start with mock. Switch to v2 after NETOPIA sandbox credentials are ready.
NETOPIA_PROVIDER=mock
NETOPIA_IS_LIVE=false
NETOPIA_API_KEY=
NETOPIA_POS_SIGNATURE=
NETOPIA_POS_SIGNATURE_SET=
NETOPIA_PUBLIC_KEY=
NETOPIA_ACTIVE_KEY=
NETOPIA_HASH_METHOD=sha512
NETOPIA_SANDBOX_BASE_URL=https://secure.sandbox.netopia-payments.com
NETOPIA_LIVE_BASE_URL=https://secure.mobilpay.ro/pay
NETOPIA_NOTIFY_URL=https://your-backend.up.railway.app/billing/netopia/ipn
NETOPIA_REDIRECT_URL=https://your-frontend.up.railway.app/billing/return
NETOPIA_CANCEL_URL=https://your-frontend.up.railway.app/billing/return
NETOPIA_CURRENCY=EUR
NETOPIA_LANGUAGE=ro
NETOPIA_IPN_SHARED_SECRET=
NETOPIA_IPN_SIGNATURE_MODE=shared_secret
NETOPIA_IPN_REQUIRE_SIGNATURE=false

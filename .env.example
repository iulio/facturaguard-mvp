# App
ENVIRONMENT=development
SECRET_KEY=change-this-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
DATABASE_URL=postgresql+psycopg2://facturaguard:facturaguard@localhost:5432/facturaguard
AUTO_CREATE_TABLES=false

# Backend
FG_ENABLE_SCHEDULER=true
FG_STATUS_CHECK_INTERVAL_MINUTES=60

# Email
FG_EMAIL_DRY_RUN=true
FG_SMTP_HOST=
FG_SMTP_PORT=587
FG_SMTP_USERNAME=
FG_SMTP_PASSWORD=
FG_EMAIL_FROM=alerts@facturaguard.local

# ANAF connector
ANAF_CONNECTOR_MODE=mock

# Basic rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120

# Frontend
NEXT_PUBLIC_API_BASE=http://localhost:8000

# File storage
FILE_STORAGE_BACKEND=local
FILE_STORAGE_PATH=./storage

# S3-compatible storage. Used when FILE_STORAGE_BACKEND=s3
S3_ENDPOINT_URL=
S3_REGION_NAME=eu-central-1
S3_BUCKET_NAME=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=


# NETOPIA mock payment provider
NETOPIA_MOCK_ENABLED=true
NETOPIA_MOCK_RETURN_URL=http://localhost:3000/billing/return
NETOPIA_MOCK_WEBHOOK_SECRET=dev-netopia-webhook-secret


# Real ANAF/SPV OAuth integration
ANAF_CONNECTOR_MODE=mock
ANAF_ENV=test
ANAF_CLIENT_ID=
ANAF_CLIENT_SECRET=
ANAF_REDIRECT_URI=http://localhost:8000/integrations/anaf/oauth/callback
ANAF_AUTH_BASE=https://logincert.anaf.ro/anaf-oauth2/v1
ANAF_API_TEST_BASE=https://webserviceapl.anaf.ro/test/FCTEL/rest
ANAF_API_PROD_BASE=https://webserviceapl.anaf.ro/prod/FCTEL/rest
ANAF_TOKEN_CONTENT_TYPE=jwt
ANAF_SCOPE=
FRONTEND_BASE_URL=http://localhost:3000
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=


# Production security hardening
SECURITY_HEADERS_ENABLED=true
# In production, replace * with your domains, for example:
# TRUSTED_HOSTS=api.facturaguard.ro,*.up.railway.app
TRUSTED_HOSTS=*


# NETOPIA Payments API v2
# Use mock for local development, v2 for real NETOPIA integration.
NETOPIA_PROVIDER=mock
NETOPIA_IS_LIVE=false
NETOPIA_API_KEY=
NETOPIA_POS_SIGNATURE=
NETOPIA_POS_SIGNATURE_SET=
NETOPIA_PUBLIC_KEY=
NETOPIA_ACTIVE_KEY=
NETOPIA_HASH_METHOD=sha512
NETOPIA_SANDBOX_BASE_URL=https://secure.sandbox.netopia-payments.com
NETOPIA_LIVE_BASE_URL=https://secure.mobilpay.ro/pay
NETOPIA_NOTIFY_URL=http://localhost:8000/billing/netopia/ipn
NETOPIA_REDIRECT_URL=http://localhost:3000/billing/return
NETOPIA_CANCEL_URL=http://localhost:3000/billing/return
NETOPIA_CURRENCY=EUR
NETOPIA_LANGUAGE=ro
NETOPIA_IPN_SHARED_SECRET=
NETOPIA_IPN_SIGNATURE_MODE=shared_secret
NETOPIA_IPN_REQUIRE_SIGNATURE=false

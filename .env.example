# App
ENVIRONMENT=development
SECRET_KEY=change-this-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
DATABASE_URL=postgresql+psycopg2://facturaguard:facturaguard@localhost:5432/facturaguard
AUTO_CREATE_TABLES=false

# Backend
FG_ENABLE_SCHEDULER=true
FG_STATUS_CHECK_INTERVAL_MINUTES=60

# Email
FG_EMAIL_DRY_RUN=true
FG_SMTP_HOST=
FG_SMTP_PORT=587
FG_SMTP_USERNAME=
FG_SMTP_PASSWORD=
FG_EMAIL_FROM=alerts@facturaguard.local

# ANAF connector
ANAF_CONNECTOR_MODE=mock

# Basic rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120

# Frontend
NEXT_PUBLIC_API_BASE=http://localhost:8000
